  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/testing": "11.1.28",
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "ioredis-mock": "^8.13.1",
    "pg-mem": "^3.0.14",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
