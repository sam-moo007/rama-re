NODE_ENV=development
IDENTITY_MODE=oidc

# ── Supabase Auth (OIDC) ───────────────────────────────────────────────────────
# Replace <project-ref> with your Supabase project reference ID
OIDC_ISSUER=https://<project-ref>.supabase.co/auth/v1
OIDC_AUDIENCE=authenticated
OIDC_JWKS_URI=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
OIDC_ROLE_CLAIM=rama_roles
OIDC_ORGANIZATION_CLAIM=rama_org_id
OIDC_REQUIRE_STAFF_MFA=true
OIDC_MFA_ACR_VALUES=urn:rama:loa:2
OIDC_CLOCK_TOLERANCE_SECONDS=30
OIDC_MAX_TOKEN_AGE_SECONDS=3600
OIDC_JWKS_TIMEOUT_MS=5000
OIDC_JWKS_CACHE_MS=300000

# ── App Ports ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
RAMA_API_INTERNAL_URL=http://localhost:4000/api/v1
WEB_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Use direct connection (port 5432) for local dev, Transaction Pooler (port 6543) for prod
DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_SSL_MODE=require
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=10000

# ── Repositories (use postgres in staging/production) ──────────────────────────
EVIDENCE_REPOSITORY=memory
EVIDENCE_SEED_FIXTURES=false
INGESTION_REPOSITORY=memory
BRIEF_REPOSITORY=memory
CATALOGUE_REPOSITORY=memory
CATALOGUE_CURSOR_SECRET=generate_this_secret_locally_with_openssl
CATALOGUE_SEARCH_INDEX=memory
CATALOGUE_SEARCH_READ_SOURCE=repository
CATALOGUE_SEARCH_CANDIDATE_CAP=2000
CATALOGUE_INDEX_RECONCILE_ENABLED=false
CATALOGUE_INDEX_RECONCILE_INTERVAL_MS=900000
SHORTLIST_REPOSITORY=memory
DECISION_CASE_REPOSITORY=memory
DECISION_CASE_RETENTION_SWEEP_MS=900000
COMMUNICATIONS_REPOSITORY=memory

# ── Supabase Storage (S3-compatible) ───────────────────────────────────────────
# Generate credentials at: Supabase Dashboard > Settings > Storage > S3 Connection
OBJECT_STORAGE_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
OBJECT_STORAGE_BUCKET=rama-local
OBJECT_STORAGE_QUARANTINE_BUCKET=rama-local-quarantine
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=<project-region>
OBJECT_STORAGE_FORCE_PATH_STYLE=true
ARTIFACT_STORE=s3

# ── Redis (keep local or use Upstash) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ingestion / Files ──────────────────────────────────────────────────────────
INGESTION_SEED_FIXTURES=false
INGESTION_MAX_PAYLOAD_BYTES=262144
PARTNER_FILE_MAX_BYTES=5000000
PARTNER_FILE_MAX_ROWS=1000

# ── Contact / Communications ───────────────────────────────────────────────────
CONTACT_ENCRYPTION_KEY_BASE64=
CONTACT_DELIVERY_ADAPTER=development
CONTACT_DELIVERY_WEBHOOK_URL=
CONTACT_DELIVERY_WEBHOOK_SECRET=

# ── Malware Scanning ───────────────────────────────────────────────────────────
MALWARE_SCANNER=deterministic
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=rama-api

# ── Mapbox (replaces Google Maps) ──────────────────────────────────────────────
# Create a secret token (sk.*) at: https://account.mapbox.com/access-tokens/
# NEVER expose sk.* tokens to the browser. Use pk.* for frontend rendering.
MAPBOX_ACCESS_TOKEN=

# ── Supabase client (public, safe for browser) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role key (server-only, NEVER expose publicly) ─────────────
SUPABASE_SERVICE_ROLE_KEY=
